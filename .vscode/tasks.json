{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🤖 AI Code Review",
      "type": "shell",
      "command": "echo",
      "args": [
        "Run GitHub Copilot Chat with '@github /explain' for comprehensive code review using Claude Sonnet 4"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "AI-powered code review using Claude models"
    },
    {
      "label": "🧪 AI Test Generation",
