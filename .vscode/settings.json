{
  "typescript.preferences.quoteStyle": "single",
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.autoImports": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  
  "rust-analyzer.checkOnSave.enable": true,
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.rustfmt.overrideCommand": ["rustfmt", "--edition", "2021"],
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.typeHints.enable": true,
  
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "yaml": true,
    "json": true,
    "typescript": true,
    "typescriptreact": true,
    "javascript": true,
    "javascriptreact": true,
    "rust": true,
    "sql": true,
    "dockerfile": true,
    "shellscript": true,
    "powershell": true
  },
  
  "github.copilot.chat.model": "copilot/claude-sonnet-4",
  "github.copilot.chat.welcomeMessage": "never",
  "github.copilot.chat.localeOverride": "en",
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.experimental.generateTests.instructions": "Generate comprehensive tests using Vitest for React components and functions. Include edge cases and error scenarios. Use TypeScript throughout.",
  
  "github.copilot.advanced": {
    "secret_key": "default",
    "length": 500,
    "temperature": 0.1,
    "top_p": 1,
    "indentationMode": {
      "typescript": "space",
      "typescriptreact": "space", 
      "javascript": "space",
      "javascriptreact": "space",
      "rust": "space",
      "json": "space",
      "yaml": "space"
    }
  },
  
  "inlineChat.acceptedOrDiscardBeforeSave": true,
  "inlineChat.finishOnType": true,
  "inlineChat.holdToSpeech": true,
  
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.enableImages": true,
  
  "files.associations": {
    "*.tsx": "typescriptreact",
    "*.ts": "typescript",
    "*.jsx": "javascriptreact", 
    "*.js": "javascript",
    "*.rs": "rust",
    "*.toml": "toml",
    "*.md": "markdown",
    "*.sql": "sql",
    "wrangler.toml": "toml",
    "*.yml": "yaml",
    "*.yaml": "yaml"
  },
  
  "files.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/.git": true,
    "**/dist": true,
    "**/.wrangler": true,
    "**/coverage": true,
    "**/.vitest": true
  },
  
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/dist": true,
    "**/.wrangler": true,
    "**/coverage": true,
    "**/.vitest": true
  },
  
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    },
    "github.copilot.enable": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true,
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "on", 
      "strings": "on"
    }
  },
  
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    },
    "github.copilot.enable": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true,
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "on",
      "strings": "on"
    }
  },
  
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    },
    "github.copilot.enable": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true
  },
  
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    },
    "github.copilot.enable": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true
  },
  
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    },
    "github.copilot.enable": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.enabled": true
  },
  
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "github.copilot.enable": true
  },
  
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode", 
    "editor.formatOnSave": true,
    "github.copilot.enable": true
  },
  
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true,
    "github.copilot.enable": true
  },
  
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "github.copilot.enable": true,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "on",
      "strings": "on", 
      "other": "on"
    }
  },
  
  "[sql]": {
    "editor.formatOnSave": false,
    "github.copilot.enable": true
  },
  
  "eslint.validate": [
    "javascript",
    "javascriptreact", 
    "typescript",
    "typescriptreact"
  ],
  "eslint.format.enable": true,
  "eslint.codeAction.showDocumentation": {
    "enable": true
  },
  
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": true,
  
  "vitest.commandLine": "npm run test",
  "vitest.include": ["**/*.{test,spec}.{js,ts,jsx,tsx}"],
  "vitest.exclude": ["**/node_modules/**", "**/dist/**"],
  
  "emmet.includeLanguages": {
    "typescript": "html",
    "typescriptreact": "html",
    "javascript": "html",
    "javascriptreact": "html"
  },
  
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },
  "editor.wordBasedSuggestions": "off",
  "editor.parameterHints.enabled": true,
  "editor.hover.enabled": true,
  
  "workbench.colorCustomizations": {
    "editorBracketHighlight.foreground1": "#FFD700",
    "editorBracketHighlight.foreground2": "#DA70D6", 
    "editorBracketHighlight.foreground3": "#87CEEB"
  },
  
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.suggestSmartCommit": true,
  
  "extensions.ignoreRecommendations": false,
  "extensions.showRecommendationsOnlyOnDemand": false,
  
  "roo-cline.vsCodeLmModelSelector": {
    "architect": "copilot/claude-sonnet-4",
    "code": "copilot/claude-sonnet-4", 
    "ask": "copilot/claude-sonnet-4",
    "debug": "copilot/claude-3.5-sonnet",
    "orchestrator": "copilot/claude-sonnet-4"
  },
  
  "roo-cline.modelPreferences": {
    "primaryProvider": "claude",
    "fallbackEnabled": true,
    "contextSwitching": true,
    "adaptiveSelection": true,
    "vibeCoderMode": true
  },
  
  "roo-cline.taskMappings": {
    "*.tsx": "copilot/claude-sonnet-4",
    "*.ts": "copilot/claude-sonnet-4",
    "*.jsx": "copilot/claude-3.5-sonnet",
    "*.js": "copilot/claude-3.5-sonnet",
    "*.rs": "copilot/claude-sonnet-4", 
    "*.sql": "copilot/claude-3.5-sonnet",
    "*.md": "copilot/claude-3.5-sonnet",
    "*.json": "copilot/claude-3.5-sonnet",
    "*.yaml": "copilot/claude-3.5-sonnet",
    "*.yml": "copilot/claude-3.5-sonnet"
  },
  
  "chat.mcp.serverSampling": {
    "Global in Code - Insiders: markitdown": {
      "allowedModels": [
        "copilot/claude-sonnet-4",
        "copilot/claude-3.5-sonnet",
        "copilot/claude-3.7-sonnet", 
        "copilot/claude-opus-4",
        "copilot/gpt-4o",
        "copilot/gpt-5",
        "copilot/gemini-2.5-pro",
        "copilot/o3",
        "copilot/auto"
      ],
      "preferredModel": "copilot/claude-sonnet-4"
    }
  },
  
  "chat.mcp.autostart": "newAndOutdated",
  "github.copilot.chat.codeGeneration.instructions": "Always prefer TypeScript over JavaScript. Follow the project's ESLint and Prettier configurations. Include proper error handling and type safety. Prioritize Claude models for complex reasoning tasks."
}
